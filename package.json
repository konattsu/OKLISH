{
  "name": "oklish",
  "version": "0.1.0",
  "type": "module",
  "description": "",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && rollup -c",
    "dev": "webpack-dev-server --config build/webpack.dev.mjs --host 0.0.0.0",
    "test": "node tests/master.test.mjs",
    "lint": "eslint src/*",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts src/*.ts",
    "format:check": "prettier --check src/**/*.ts tests/*.mjs",
    "clean": "rm -rf dist",
    "prepare": "husky",
    "size": "rm -rf dist && npm run build && npx terser dist/oklish.js -o dist/oklish.min.js --compress --mangle && gzip -k dist/oklish.js dist/oklish.min.js && ls -lh dist/oklish.js dist/oklish.js.gz dist/oklish.min.js dist/oklish.min.js.gz"
  },
  "keywords": [],
  "author": "Stasshe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stasshe/"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/node": "24.5.1",
    "@types/react": "^19.1.14",
    "@types/react-dom": "^19.1.9",
    "@types/react-rnd": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "8.44.0",
    "@typescript-eslint/parser": "8.44.0",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "html-webpack-plugin": "^5.6.4",
    "husky": "9.1.7",
    "lint-staged": "16.1.6",
    "prettier": "3.6.2",
    "rollup": "^4.21.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "terser": "^5.44.0",
    "ts-loader": "^9.5.4",
    "typescript": "5.9.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-rnd": "^10.5.2"
  }
}
