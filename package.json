{
  "name": "stasshe-npm",
  "version": "0.1.1",
  "type": "module",
  "description": "",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && rollup -c",
    "dev": "tsc --watch",
    "test": "node tests/master.test.mjs",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts tests/*.mjs",
    "format:check": "prettier --check src/**/*.ts tests/*.mjs",
    "clean": "rm -rf dist",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Stasshe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stasshe/"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "24.5.1",
    "@typescript-eslint/eslint-plugin": "8.44.0",
    "@typescript-eslint/parser": "8.44.0",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "husky": "9.1.7",
    "lint-staged": "16.1.6",
    "prettier": "3.6.2",
    "rollup": "^4.21.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
